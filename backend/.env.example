# Backend email SMTP configuration.
# For Gmail, use your Gmail address and a Google App Password, not your normal password.
# Create one at: Google Account > Security > 2-Step Verification > App passwords.
EMAIL_ADDRESS=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_SMTP_PORT=465
EMAIL_USE_SSL=true

# Stripe settings for online checkout
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
# Optional: Stripe webhook secret if you add webhook event handling
STRIPE_WEBHOOK_SECRET=

# Optional OpenAI API key for enhanced AI suggestions
OPENAI_API_KEY=

# Frontend host used for Stripe redirect URLs
FRONTEND_URL=http://localhost:5173
